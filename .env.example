# Ambiente
APP_ENV=local
# Em produção, mude para production (ou qualquer valor != local) — isso ativa
# o cookie de sessão como "Secure" (só trafega em HTTPS).
APP_SECRET=troque-esta-chave
DATABASE_URL=sqlite:///./buscador_processos.db

# DataJud/CNJ - OPCIONAL. Deixe vazio pra usar a chave pública oficial do CNJ,
# que já vem embutida no código (app/config.py, DEFAULT_DATAJUD_PUBLIC_API_KEY).
# Só preencha aqui se o CNJ rotacionar a chave pública e o valor embutido
# parar de funcionar — confira o valor atual em datajud-wiki.cnj.jus.br/api-publica/acesso
DATAJUD_API_KEY=
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_TIMEOUT_SECONDS=40
DATAJUD_PAGE_SIZE=50

# Segurança interna simples: se definido, exige header X-Internal-Token nas rotas /api/*.
INTERNAL_API_TOKEN=

# Senha simples para proteger a tela (login por sessão via cookie).
# Vazio = tela aberta, sem login (comportamento atual). Defina antes de publicar em URL pública.
APP_LOGIN_PASSWORD=
# Mantém o login salvo no navegador por este número de dias.
SESSION_TTL_DAYS=90

# Origens (domínios) autorizadas por CORS a chamar a API a partir de um frontend
# publicado separadamente (ex.: HTML estático no Netlify/Vercel/GitHub Pages).
# Múltiplas origens separadas por vírgula. Vazio = nenhuma origem cross-origin liberada.
# Nunca usar "*" aqui em produção.
# Ex.: FRONTEND_ALLOWED_ORIGINS=https://meu-html.netlify.app,https://outro-dominio.com
FRONTEND_ALLOWED_ORIGINS=

# Conector STJ (stj_precatorios): modo offline opcional. Aponte para uma pasta
# com os XLSX/XLSM baixados manualmente da página oficial do STJ para consultar
# sem rede. Vazio = modo online (o conector lê a página oficial e baixa sozinho).
STJ_LOCAL_DIR=
# Pasta de uploads manuais do STJ. Em produção com disco persistente, use /data/stj_uploads.
STJ_UPLOAD_DIR=data/stj_uploads

# Pasta de anexos do registro manual de evidência. Em produção com disco persistente, use /data/evidencias_manuais.
EVIDENCE_UPLOAD_DIR=data/evidencias_manuais

# Conectores oficiais de precatórios/TRFs/TJs/SisPreq/PDPJ devem ser adicionados conforme credenciais reais.
# Ex.: TRIBUNAL_PRECAT_BASE_URL=
# Ex.: TRIBUNAL_PRECAT_TOKEN=

# API Serpro Consulta CND (Receita Federal + PGFN) — serviço oficial PAGO,
# contratado na Loja Serpro (https://loja.serpro.gov.br/consultacnd).
# Vazio = o certificate_center responde 'requer_api_contratada' honestamente.
SERPRO_CND_CONSUMER_KEY=
SERPRO_CND_CONSUMER_SECRET=
SERPRO_CND_CODIGO_IDENTIFICACAO=

# Automação de navegador com pausa em captcha (app/services/captcha_relay.py).
# Exige Playwright + Chromium instalados no servidor (pesado: ~300-400MB extra
# na imagem de deploy). Depois de "pip install playwright", rode também:
#   playwright install --with-deps chromium
# Se seu host já tiver um Chrome/Chromium instalado (ex.: buildpack próprio),
# aponte para ele aqui em vez de instalar outro:
PLAYWRIGHT_CHROME_PATH=

# v31: token de verificação do webhook do WhatsApp Business Cloud API (Meta).
# Vazio = webhook desativado (decisão deliberada: não ativar WhatsApp Business ainda).
WHATSAPP_VERIFY_TOKEN=

# v32.1: se true, leads de prioridade alta acionam bots automaticamente quando
# o watcher roda. Default false (não sobrecarregar sem pedir).
WATCHERS_AUTO_RUN_BOTS=false

# Salt pro hash de CPF/CNPJ do credor no índice processual pessoal — permite
# buscar por documento sem guardar o número em claro em lugar nenhum.
# TEM QUE ser sobrescrito em produção (valor de dev abaixo gera aviso em
# /api/watchers/status se continuar em uso).
INDICE_CPF_HASH_SALT=buscador-processos-indice-nacional-salt-dev-only
